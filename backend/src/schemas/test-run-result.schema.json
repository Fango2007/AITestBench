{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/test-run-result.schema.json",
  "title": "Scenario Test Run Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "started_at",
    "ended_at",
    "test",
    "profile",
    "server_instance",
    "steps",
    "summary",
    "effective_settings"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this persistence schema.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this run (UUID recommended)."
    },
    "status": {
      "type": "string",
      "description": "Overall run result.",
      "enum": ["pass", "fail", "error", "skipped"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 timestamp when the run started."
    },
    "ended_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 timestamp when the run ended (even on failure)."
    },
    "duration_ms": {
      "type": "number",
      "description": "Convenience: ended_at - started_at in milliseconds.",
      "minimum": 0
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "platform": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "os": { "type": "string" },
            "arch": { "type": "string" },
            "runtime": {
              "type": "string",
              "description": "e.g. node@20.11.1, python@3.12.2"
            }
          }
        },
        "hardware_snapshot": {
          "type": ["object", "null"],
          "description": "Client machine hardware snapshot captured by the runner.",
          "additionalProperties": true
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": ["string", "null"] },
        "type": { "type": "string", "enum": ["scenario-json", "scenario-python"] },
        "definition_ref": {
          "type": ["string", "null"],
          "description": "Path/URI to the test definition used for this run (optional)."
        },
        "definition_sha256": {
          "type": ["string", "null"],
          "description": "SHA-256 of the exact test definition bytes used.",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "archived": {
          "type": "boolean",
          "default": false,
          "description": "Snapshot of test archive status at execution time."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": ["string", "null"] },
        "definition_ref": { "type": ["string", "null"] },
        "definition_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "server_instance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_key",
        "base_url",
        "retrieved_at",
        "runtime_snapshot",
        "capabilities_snapshot",
        "models_snapshot"
      ],
      "properties": {
        "cache_key": {
          "type": "string",
          "description": "Stable key for metadata caching (e.g. base_url + auth identity)."
        },
        "base_url": { "type": "string" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "ttl_ms": { "type": "integer", "minimum": 0, "default": 300000 },
        "capabilities_snapshot": {
          "type": ["object", "null"],
          "description": "Optional snapshot of server capabilities at run time (shape matches inference server schema’s capabilities section)."
        },
        "runtime_snapshot": {
          "type": ["object", "null"],
          "description": "Optional snapshot: server runtime version, platform, backend engine."
        },
        "models_snapshot": {
          "type": ["array", "null"],
          "description": "Optional list of models visible at run time (minimal identifying info).",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "hardware_snapshot": {
          "type": ["object", "null"],
          "description": "Server-side hardware snapshot when exposed by the server or collected out-of-band.",
          "additionalProperties": true
        }
      }
    },
    "selected_model": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "description": "Optional snapshot of the model primarily used in this run.",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "alias": { "type": ["string", "null"] },
        "metadata": {
          "type": ["object", "null"],
          "description": "Optional model metadata snapshot (shape matches model schema subset).",
          "additionalProperties": true
        },
        "retrieved_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": true,
      "description": "Resolved env vars (only those explicitly whitelisted by runner config)."
    },
    "vars_initial": {
      "type": "object",
      "additionalProperties": true,
      "description": "Initial vars after templating and profile merge (before step 1)."
    },
    "vars_final": {
      "type": "object",
      "additionalProperties": true,
      "description": "Final vars after last step extraction (for debugging/replay)."
    },
    "effective_settings": {
      "type": "object",
      "additionalProperties": false,
      "description": "Run-level snapshot of effective defaults and behavioural settings after profile/test overrides. Unknown values MUST be recorded as null.",
      "required": ["generation", "context", "transport"],
      "properties": {
        "generation": {
          "type": ["object", "null"],
          "description": "Effective generation defaults (unknowns as null).",
          "additionalProperties": false,
          "properties": {
            "temperature": { "type": ["number", "null"], "minimum": 0 },
            "top_p": { "type": ["number", "null"], "minimum": 0 },
            "max_tokens": { "type": ["integer", "null"], "minimum": 0 },
            "tool": { "type": ["string", "null"] },
            "tool_choice": { "type": ["string", "null"] },
            "parallel_tool_calls": { "type": ["boolean", "null"] }
          }
        },
        "context": {
          "type": ["object", "null"],
          "description": "Effective context-window + truncation behaviour (unknowns as null).",
          "additionalProperties": false,
          "properties": {
            "context_window_tokens": { "type": ["integer", "null"], "minimum": 0 },
            "max_input_tokens": { "type": ["integer", "null"], "minimum": 0 },
            "truncation_strategy": { "type": ["string", "null"] },
            "system_prompt_strategy": { "type": ["string", "null"] }
          }
        },
        "transport": {
          "type": ["object", "null"],
          "description": "Effective transport defaults (streaming, formats, etc.; unknowns as null).",
          "additionalProperties": false,
          "properties": {
            "stream": { "type": ["boolean", "null"] },
            "format": {
              "type": ["string", "null"],
              "enum": ["sse", "jsonl", "chunked", "unknown", null]
            }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/StepResult" }
    },
    "final_assert": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/AssertionOutcome" },
      "description": "Outcomes of final_assert evaluation (if defined)."
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed_steps", "failed_steps", "errors", "warnings"],
      "properties": {
        "passed_steps": { "type": "integer", "minimum": 0 },
        "failed_steps": { "type": "integer", "minimum": 0 },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/RunError" },
          "default": []
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/RunWarning" },
          "default": []
        },
        "aggregates": {
          "type": ["object", "null"],
          "description": "Optional aggregated metrics across steps.",
          "additionalProperties": true
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_bodies_external": {
          "type": "boolean",
          "default": false,
          "description": "True if large request bodies were stored as separate files."
        },
        "response_bodies_external": {
          "type": "boolean",
          "default": false,
          "description": "True if large response bodies were stored as separate files."
        },
        "external_map": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Map from internal artifact key to filesystem path/URI."
        }
      }
    }
  },
  "$defs": {
    "StepResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "id",
        "name",
        "status",
        "request",
        "response",
        "assertions",
        "metrics"
      ],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "id": { "type": "string", "description": "Stable per-step id (UUID recommended)." },
        "name": { "type": ["string", "null"] },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "error", "skipped"]
        },
        "attempts": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "How many HTTP attempts were made (includes retries)."
        },
        "request": { "$ref": "#/$defs/RequestSnapshot" },
        "response": { "$ref": "#/$defs/NormalisedResponse" },
        "extract": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/ExtractOutcome" }
        },
        "vars_delta": {
          "type": "object",
          "additionalProperties": true,
          "description": "Only vars created/changed in this step (after extraction)."
        },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/AssertionOutcome" }
        },
        "metrics": { "$ref": "#/$defs/Metrics" },
        "timing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "started_at": { "type": ["string", "null"], "format": "date-time" },
            "ended_at": { "type": ["string", "null"], "format": "date-time" }
          }
        },
        "error": { "$ref": "#/$defs/StepError" },
        "notes": {
          "type": ["string", "null"],
          "description": "Free-form debug notes written by the runner (not by tests)."
        }
      }
    },
    "RequestSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "url", "headers"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        },
        "url": { "type": "string" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "query": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        },
        "body": {
          "type": ["object", "array", "string", "number", "boolean", "null"],
          "description": "Resolved request body used for this attempt (may be truncated or externalised)."
        },
        "body_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "transport": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "stream": { "type": "boolean", "default": false },
            "format": {
              "type": ["string", "null"],
              "enum": ["sse", "jsonl", "chunked", "unknown", null]
            }
          }
        },
        "timeout_ms": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "NormalisedResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "headers", "metrics"],
      "properties": {
        "status": { "type": "integer" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": {
          "type": ["object", "array", "null"],
          "description": "Parsed JSON body when parse succeeded, else null."
        },
        "text": {
          "type": ["string", "null"],
          "description": "Raw body as text if non-JSON or parse failed (may be truncated)."
        },
        "body_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "stream": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "format": { "type": "string", "enum": ["sse", "jsonl", "chunked", "unknown"] },
            "events": {
              "type": "array",
              "items": { "$ref": "#/$defs/StreamEvent" }
            },
            "done": { "type": "boolean" }
          }
        },
        "metrics": { "$ref": "#/$defs/Metrics" }
      }
    },
    "StreamEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw", "done"],
      "properties": {
        "raw": { "type": "string" },
        "json": {
          "type": ["object", "array", "null"],
          "description": "Parsed JSON for this event when possible."
        },
        "done": { "type": "boolean" },
        "seq": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "Metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ttfb_ms", "total_ms"],
      "properties": {
        "ttfb_ms": { "type": "number", "minimum": 0 },
        "total_ms": { "type": "number", "minimum": 0 },
        "bytes_in": { "type": ["integer", "null"], "minimum": 0 },
        "bytes_out": { "type": ["integer", "null"], "minimum": 0 },
        "tokens_in": { "type": ["integer", "null"], "minimum": 0 },
        "tokens_out": { "type": ["integer", "null"], "minimum": 0 },
        "tok_s": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Optional: output token/s (if computed)."
        }
      }
    },
    "ExtractOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "from", "selector"],
      "properties": {
        "name": { "type": "string" },
        "from": { "type": "string", "enum": ["status", "headers", "body", "text", "stream", "metrics"] },
        "selector": { "type": "string" },
        "transform": {
          "type": ["string", "null"],
          "enum": ["string", "int", "float", "bool", "json", null]
        },
        "value": {
          "type": ["object", "array", "string", "number", "boolean", "null"],
          "description": "The value written to vars (after transform)."
        }
      }
    },
    "AssertionOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "op", "passed"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": ["string", "null"],
          "description": "Optional assertion type label from test definition."
        },
        "target": {
          "type": "string",
          "enum": ["status", "headers", "body", "text", "stream", "metrics", "vars"]
        },
        "selector": { "type": ["string", "null"] },
        "op": { "type": "string" },
        "expected": { "type": ["object", "array", "string", "number", "boolean", "null"] },
        "actual": {
          "type": ["object", "array", "string", "number", "boolean", "null"],
          "description": "Value under test after selector resolution (captured for debugging)."
        },
        "severity": { "type": "string", "enum": ["error", "warn"], "default": "error" },
        "when": { "type": ["string", "null"], "description": "Original condition expression, if present." },
        "passed": { "type": "boolean" },
        "message": { "type": ["string", "null"], "description": "Runner-generated failure explanation." }
      }
    },
    "StepError": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "timeout",
            "connection_error",
            "http_error",
            "templating_error",
            "assertion_failed",
            "schema_error",
            "unknown"
          ]
        },
        "message": { "type": "string" },
        "details": { "type": ["object", "null"], "additionalProperties": true }
      }
    },
    "RunError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "step_index": { "type": ["integer", "null"], "minimum": 0 },
        "details": { "type": ["object", "null"], "additionalProperties": true }
      }
    },
    "RunWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "step_index": { "type": ["integer", "null"], "minimum": 0 },
        "details": { "type": ["object", "null"], "additionalProperties": true }
      }
    }
  }
}
