{
  "json_defined_test_template_schema_version": "1.0.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scenario Test Template Schema",
  "type": "object",
  "required": ["id", "version", "steps"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "lifecycle": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "since": { "type": "string" },
        "deprecated_since": { "type": ["string", "null"] },
        "archived_since": { "type": ["string", "null"] },
        "superseded_by": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] }
      }
    },
    "vars": {
      "type": "object",
      "additionalProperties": true
    },
    "defaults": {
      "type": "object",
      "properties": {
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "timeout_ms": { "type": "number" },
        "retries": {
          "type": "object",
          "properties": {
            "max": { "type": "number" },
            "backoff_ms": { "type": "number" }
          },
          "required": ["max", "backoff_ms"]
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "request"],
        "properties": {
          "id": { "type": "string" },
          "request": {
            "type": "object",
            "required": ["method", "url"],
            "properties": {
              "method": { "type": "string" },
              "url": { "type": "string" },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "query": {
                "type": "object",
                "additionalProperties": true
              },
              "body": { "type": ["object", "array", "string", "null"] },
              "body_template": { "type": ["object", "array", "string"] },
              "timeout_ms": { "type": "number" },
              "transport": {
                "type": "object",
                "properties": {
                  "stream": { "type": "boolean" },
                  "format": {
                    "type": "string",
                    "enum": ["sse", "jsonl", "chunked", "unknown"]
                  }
                }
              }
            }
          },
          "extract": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["var", "from", "selector"],
              "properties": {
                "var": { "type": "string" },
                "from": {
                  "type": "string",
                  "enum": ["status", "headers", "body", "text", "stream", "metrics", "vars"]
                },
                "selector": { "type": "string" },
                "transform": {
                  "type": "string",
                  "enum": ["string", "int", "float", "bool", "json"]
                }
              }
            }
          },
          "assert": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "target", "op"],
              "properties": {
                "type": { "type": "string" },
                "target": {
                  "type": "string",
                  "enum": ["status", "headers", "body", "text", "stream", "metrics", "vars"]
                },
                "selector": { "type": "string" },
                "op": {
                  "type": "string",
                  "enum": ["exists", "==", "!=", "contains", "matches", "in", "not_in", "lt", "lte", "gt", "gte"]
                },
                "expected": {},
                "severity": {
                  "type": "string",
                  "enum": ["error", "warn"],
                  "default": "error"
                },
                "when": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "final_assert": {
      "type": "array",
      "items": { "$ref": "#/properties/steps/items/properties/assert/items" }
    }
  }
}
