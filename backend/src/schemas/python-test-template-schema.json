{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/python-test-template-schema.v1.json",
  "title": "Python Test Template Schema (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "id",
    "name",
    "version",
    "lifecycle",
    "python",
    "contracts",
    "defaults",
    "outputs"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "python_test"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v\\d+$",
      "description": "Schema version of this template (e.g., v1)."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for the test (unique across all tests)."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Test version for result provenance (semver recommended)."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "archived", "deprecated"]
        },
        "since": {
          "type": "string",
          "description": "ISO date-time when lifecycle status took effect."
        },
        "until": {
          "type": "string",
          "description": "ISO date-time when this test should no longer run (optional)."
        },
        "replaced_by": {
          "type": "string",
          "description": "Optional test id that supersedes this test."
        },
        "reason": {
          "type": "string",
          "description": "Human-readable explanation."
        }
      }
    },
    "python": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "entrypoint"],
      "properties": {
        "module": {
          "type": "string",
          "description": "Python import path (or file path resolution key) for the test implementation."
        },
        "entrypoint": {
          "type": "string",
          "description": "Callable name within module. Must be invokable as entrypoint(context, spec) -> Result."
        },
        "requirements": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pip": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Optional pip requirements. Runner may preinstall in venv."
            }
          },
          "default": {}
        },
        "sandbox": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "network": {
              "type": "string",
              "enum": ["allow", "deny"],
              "default": "allow"
            },
            "filesystem": {
              "type": "string",
              "enum": ["read", "read_write", "deny"],
              "default": "read"
            }
          },
          "default": {}
        }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires", "provides"],
      "properties": {
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Capabilities/contract keys this test needs (e.g., http.streaming.sse, models.list)."
        },
        "provides": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Capabilities/contract keys this test validates."
        }
      }
    },
    "vars": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "Initial vars (templated) made available to the test entrypoint."
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_ms": { "type": "integer", "minimum": 1, "default": 60000 },
        "retries": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max": { "type": "integer", "minimum": 0, "default": 0 },
            "backoff_ms": { "type": "integer", "minimum": 0, "default": 0 },
            "retry_on_status": {
              "type": "array",
              "items": { "type": "integer" },
              "default": [429, 503]
            }
          },
          "default": {}
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        }
      },
      "default": {}
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "Test-specific parameters passed to the entrypoint as spec.parameters."
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_schema", "normalised_response"],
      "properties": {
        "result_schema": {
          "type": "string",
          "const": "scenario_result.v1",
          "description": "The runner MUST persist results in the unified Scenario Result format."
        },
        "normalised_response": {
          "type": "string",
          "const": "response_normalisation.v1",
          "description": "The runner MUST expose and persist the same normalised response object as Scenario tests."
        }
      }
    }
  }
}
