{
  "kind": "python_test",
  "schema_version": "v1",
  "id": "Cold_start_penalty",
  "name": "Cold_start_penalty",
  "description": "Estimates model cold-start penalty by comparing first request latency vs immediate follow-up latency.",
  "version": "1.0.0",
  "tags": [
    "perf",
    "latency",
    "startup"
  ],
  "lifecycle": {
    "status": "active",
    "since": "2026-01-21"
  },
  "python": {
    "module": "tests_python.cold_start_penalty",
    "entrypoint": "entrypoint"
  },
  "contracts": {
    "requires": [
      "http"
    ],
    "provides": [
      "perf.cold_start_penalty"
    ]
  },
  "defaults": {
    "timeout_ms": 300000,
    "retries": {
      "max": 0,
      "backoff_ms": 0
    }
  },
  "parameters": {
    "request": {
      "url": "{{profile.server.base_url}}/v1/chat/completions",
      "method": "POST",
      "headers": {
        "content-type": "application/json"
      },
      "body": {
        "model": "{{profile.selection.model}}",
        "stream": false,
        "temperature": 0,
        "max_completion_tokens": 64,
        "messages": [
          {
            "role": "system",
            "content": "You are a concise assistant."
          },
          {
            "role": "user",
            "content": "Reply with exactly: OK"
          }
        ]
      }
    },
    "iterations": 5,
    "sleep_between_ms": 60000,
    "cold_condition": {
      "mode": "unload",
      "note": "If your server supports eviction/unload, set mode accordingly."
    },
    "aggregation": {
      "primary": "median",
      "also_compute": [
        "mean",
        "p95"
      ]
    }
  },
  "outputs": {
    "result_schema": "scenario_result.v1",
    "normalised_response": "response_normalisation.v1"
  }
}