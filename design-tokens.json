{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "AITestBench",
    "version": "0.2.0",
    "description": "Design tokens extracted from the live CSS and React components. Import via Tokens Studio for Figma or compile with Style Dictionary."
  },

  "color": {
    "$type": "color",

    "background": {
      "page": {
        "$value": "radial-gradient(circle at top, #f5f1ea 0%, #efe9df 45%, #e4ddd1 100%)",
        "$description": "Full-page background gradient (warm parchment)"
      },
      "surface": {
        "$value": "#fffdf8",
        "$description": "Card / modal surface — near-white warm tint"
      },
      "surface-subtle": {
        "$value": "#f9f6ef",
        "$description": "List items, row stripes, inner panels"
      },
      "surface-input": {
        "$value": "#fffdfa",
        "$description": "Input, select, textarea background"
      },
      "header": {
        "$value": "linear-gradient(120deg, rgba(255,249,241,0.9), rgba(240,233,223,0.9))",
        "$description": "App-header frosted gradient"
      },
      "nav-active": {
        "$value": "#fff4e6",
        "$description": "Active nav button fill"
      },
      "tab-active": {
        "$value": "#fff8ea",
        "$description": "Active details-tab background"
      },
      "tab-inactive": {
        "$value": "#e9e3d9",
        "$description": "Inactive details-tab background"
      },
      "code-block": {
        "$value": "#f6f1e6",
        "$description": "Inline code-block background (light)"
      },
      "pre": {
        "$value": "#171615",
        "$description": "Dark code <pre> background"
      },
      "selected": {
        "$value": "#fff1d6",
        "$description": "Selected list-item highlight"
      },
      "error": {
        "$value": "#ffe8e5",
        "$description": "Error message background"
      }
    },

    "text": {
      "primary": {
        "$value": "#1b1a17",
        "$description": "Default body text"
      },
      "secondary": {
        "$value": "#4f4a43",
        "$description": "Secondary / dimmed text"
      },
      "muted": {
        "$value": "#6a645b",
        "$description": "Muted labels, meta, table headers"
      },
      "subtle": {
        "$value": "#5b554c",
        "$description": "Subhead / footnote text"
      },
      "footnote": {
        "$value": "#7a7266",
        "$description": "Status-rail footnotes, tab sub-labels"
      },
      "eyebrow": {
        "$value": "#645f57",
        "$description": "Eyebrow / uppercase label text"
      },
      "env-key": {
        "$value": "#2b2821",
        "$description": "Env-key label (bold)"
      },
      "strong": {
        "$value": "#2d2a25",
        "$description": "Metric strong values, tab names"
      },
      "on-dark": {
        "$value": "#f9f6ef",
        "$description": "Text on dark (button fill, <pre>)"
      },
      "on-dark-subtle": {
        "$value": "#f2efe8",
        "$description": "Disabled button text"
      },
      "pre-body": {
        "$value": "#f9f6ef",
        "$description": "Text inside dark <pre> blocks"
      }
    },

    "border": {
      "default": {
        "$value": "#dacfc0",
        "$description": "Card, modal, metrics-card border"
      },
      "input": {
        "$value": "#c7c0b3",
        "$description": "Input / select / textarea border"
      },
      "nav-button": {
        "$value": "#d8d1c4",
        "$description": "Nav icon-button border (default)"
      },
      "nav-button-active": {
        "$value": "#c8bfb2",
        "$description": "Nav icon-button border (active)"
      },
      "tab": {
        "$value": "#cfc7bc",
        "$description": "Details-tab border"
      },
      "tab-active": {
        "$value": "#b79c6a",
        "$description": "Active details-tab border (golden)"
      },
      "tabs-underline": {
        "$value": "#d9d1c6",
        "$description": "Tabs row underline"
      },
      "divider": {
        "$value": "#e1d8cb",
        "$description": "Section dividers, detail-row dashes"
      },
      "selected": {
        "$value": "#b59862",
        "$description": "Selected list-item border"
      },
      "header-bottom": {
        "$value": "#d4cbbf",
        "$description": "App-header bottom border"
      },
      "table-row": {
        "$value": "#e1dbcf",
        "$description": "Table row bottom border"
      },
      "error": {
        "$value": "#f4c7c3",
        "$description": "Error box border"
      },
      "health": {
        "$value": "#d7cdbf",
        "$description": "Health-indicator pill border"
      },
      "tabs-pill": {
        "$value": "#b8b1a5",
        "$description": "Simple .tabs button border"
      }
    },

    "interactive": {
      "primary-fill": {
        "$value": "#1b1a17",
        "$description": "Default button background (near-black warm)"
      },
      "primary-fill-pending": {
        "$value": "#3f3a33",
        "$description": "Button background when request is in-flight"
      },
      "primary-fill-disabled": {
        "$value": "#b8b1a5",
        "$description": "Disabled button background"
      },
      "tabs-active-fill": {
        "$value": "#1b1a17",
        "$description": "Active .tabs button fill"
      }
    },

    "semantic": {
      "success": {
        "$value": "#2f9e44",
        "$description": "Status OK / health up — green"
      },
      "error": {
        "$value": "#c92a2a",
        "$description": "Status failed / health down — red"
      },
      "error-icon": {
        "$value": "#b42318",
        "$description": "Danger icon-button and error text"
      },
      "pending": {
        "$value": "#b3aca2",
        "$description": "Pending / unknown status — neutral warm grey"
      },
      "pending-text": {
        "$value": "#766f66",
        "$description": "Pending status text colour"
      },
      "warning-dot": {
        "$value": "#f2c94c",
        "$description": "Animated yellow pulse on is-pending button"
      }
    },

    "overlay": {
      "modal": {
        "$value": "rgba(27, 26, 23, 0.4)",
        "$description": "Modal backdrop"
      }
    }
  },

  "typography": {
    "$type": "typography",

    "fontFamily": {
      "sans": {
        "$value": ["IBM Plex Sans", "Segoe UI", "sans-serif"],
        "$description": "Primary UI typeface"
      },
      "mono": {
        "$value": ["IBM Plex Mono", "SFMono-Regular", "Consolas", "Liberation Mono", "Menlo", "monospace"],
        "$description": "Monospace — textareas, code blocks"
      }
    },

    "fontSize": {
      "xs": { "$value": "11px", "$description": "Eyebrow labels, footnotes, table headers" },
      "sm": { "$value": "12px", "$description": "Meta text, health indicators, chart toggles" },
      "base": { "$value": "13px", "$description": "Table cells, textarea body, models rows" },
      "md": { "$value": "14px", "$description": "Default body / form text" },
      "lg": { "$value": "24px", "$description": "h2 page headings" }
    },

    "fontWeight": {
      "regular": { "$value": 400 },
      "semibold": { "$value": 600, "$description": "Strong values, tab names, collapsible summary" }
    },

    "letterSpacing": {
      "eyebrow": { "$value": "0.18em", "$description": ".eyebrow uppercase labels" },
      "label": { "$value": "0.12em", "$description": "Metrics titles, table headers" },
      "heading": { "$value": "-0.02em", "$description": "h1/h2/h3 negative tracking" }
    },

    "textTransform": {
      "eyebrow": { "$value": "uppercase" },
      "label": { "$value": "uppercase" }
    }
  },

  "spacing": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "1": { "$value": "2px" },
    "2": { "$value": "4px" },
    "3": { "$value": "6px" },
    "4": { "$value": "8px" },
    "5": { "$value": "10px" },
    "6": { "$value": "12px" },
    "7": { "$value": "14px" },
    "8": { "$value": "16px" },
    "10": { "$value": "20px" },
    "12": { "$value": "24px" },
    "16": { "$value": "32px" },
    "48": { "$value": "48px", "$description": "Page bottom padding" },
    "64": { "$value": "64px", "$description": "Page bottom padding (desktop)" }
  },

  "borderRadius": {
    "$type": "dimension",
    "pill": { "$value": "999px", "$description": "Buttons, health-indicator pills, dots" },
    "input": { "$value": "8px", "$description": "Inputs, selects, textareas" },
    "card": { "$value": "16px", "$description": "Cards, modals" },
    "card-sm": { "$value": "14px", "$description": "Metrics card" },
    "list-item": { "$value": "12px", "$description": "List items, models-server-card, pre" },
    "row": { "$value": "10px", "$description": "Models rows, error boxes" },
    "tab": { "$value": "10px 10px 0 0", "$description": "Details tab (top corners only)" },
    "nav-button": { "$value": "14px", "$description": "Sidebar icon buttons" },
    "icon-button": { "$value": "999px", "$description": "Inline icon-action buttons" }
  },

  "shadow": {
    "$type": "shadow",
    "card": {
      "$value": "0 12px 30px rgba(27, 26, 23, 0.08)",
      "$description": "Default card elevation"
    },
    "header": {
      "$value": "0 12px 30px rgba(24, 22, 18, 0.08)",
      "$description": "App-header shadow"
    },
    "metrics-card": {
      "$value": "0 12px 24px rgba(27, 26, 23, 0.08)",
      "$description": "Metrics card shadow"
    },
    "nav-button": {
      "$value": "0 8px 16px rgba(27, 26, 23, 0.14)",
      "$description": "Nav icon-button default"
    },
    "nav-button-active": {
      "$value": "inset 0 2px 4px rgba(27, 26, 23, 0.18), 0 4px 10px rgba(27, 26, 23, 0.12)",
      "$description": "Nav icon-button pressed state"
    },
    "nav-button-pressed": {
      "$value": "inset 0 3px 6px rgba(27, 26, 23, 0.22), 0 2px 6px rgba(27, 26, 23, 0.12)",
      "$description": "Nav icon-button :active (click)"
    },
    "modal": {
      "$value": "0 20px 40px rgba(27, 26, 23, 0.2)",
      "$description": "Modal card elevation"
    },
    "health-indicator": {
      "$value": "0 8px 18px rgba(27, 26, 23, 0.12)",
      "$description": "Health pill shadow"
    },
    "health-dot-up": {
      "$value": "0 0 0 4px rgba(47, 158, 68, 0.2)",
      "$description": "Green halo on up/ok status dot"
    },
    "health-dot-down": {
      "$value": "0 0 0 4px rgba(201, 42, 42, 0.2)",
      "$description": "Red halo on failed/down status dot"
    },
    "health-dot-pending": {
      "$value": "0 0 0 4px rgba(179, 172, 162, 0.2)",
      "$description": "Grey halo on pending status dot"
    }
  },

  "transition": {
    "$type": "transition",
    "button-hover": {
      "$value": "transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease",
      "$description": "Nav icon-button hover/focus transition"
    },
    "button-press": {
      "$value": "translateY(2px)",
      "$description": "Nav icon-button :active transform"
    }
  },

  "layout": {
    "$description": "Key layout dimensions and breakpoints",

    "pageMaxWidth": {
      "default": { "$value": "960px" },
      "wide": { "$value": "1200px", "$description": "Targets / Leaderboard pages" }
    },

    "sidebar": {
      "width": { "$value": "72px", "$description": "Collapsed icon-only sidebar" }
    },

    "breakpoint": {
      "mobile": { "$value": "900px", "$description": "Sidebar collapses to top bar; grids stack" },
      "table-narrow": { "$value": "980px", "$description": "Dashboard filter rows stack" }
    },

    "modal": {
      "defaultWidth": { "$value": "min(560px, 100%)" },
      "settingsWidth": { "$value": "min(720px, 100%)" }
    },

    "chart": {
      "height": { "$value": "360px", "$description": "Results chart default height" }
    },

    "navButton": {
      "size": { "$value": "44px", "$description": "Nav icon-button width and height" }
    },

    "inputHeight": {
      "default": { "$value": "34px", "$description": "Field inputs and selects" }
    }
  },

  "component": {
    "$description": "Per-component design notes for Figma frames",

    "AppShell": {
      "structure": "Vertical flex column. Header (fixed top) → body (sidebar + main). Background: radial parchment gradient.",
      "header": "Flex row: brand-row left, metrics-cards right. Bottom border 2px. Frosted gradient background.",
      "sidebar": "72px icon-only column nav. Scrolls with page. Collapses to horizontal row below 900px."
    },

    "MetricsCard": {
      "size": "min-width 220px. Rounded-14 card with border, soft shadow.",
      "row": "12px font, label left / value right, value font-weight 600."
    },

    "HealthIndicator": {
      "shape": "Pill (radius 999px). 10×10 dot with coloured halo glow. Three states: up (green), down (red), pending (warm grey).",
      "font": "12px, color text/secondary."
    },

    "Button": {
      "default": "Pill radius. Dark fill #1b1a17, cream text. No border.",
      "disabled": "Warm grey fill, cream text, opacity 0.7, cursor not-allowed.",
      "pending": "Darker fill #3f3a33 + animated yellow dot (pulse keyframe, 1.2s) at right edge.",
      "icon-button": "Pill radius, 32px min-width. danger variant: fill #b42318.",
      "nav-button": "44×44px square with radius-14. Transparent default; warm cream active; inset shadow on active/pressed."
    },

    "Card": {
      "background": "#fffdf8",
      "border": "1px solid #dacfc0, radius-16",
      "shadow": "0 12px 30px rgba(27,26,23,0.08)",
      "padding": "16px"
    },

    "ListItem": {
      "background": "#f9f6ef",
      "radius": "12px",
      "padding": "12px",
      "selected": "border 1px #b59862, background #fff1d6"
    },

    "Modal": {
      "overlay": "rgba(27,26,23,0.4) full-screen backdrop",
      "card": "background #fffdf8, border 1px #dacfc0, radius-16, shadow modal, width min(560px, 100%)"
    },

    "Tabs": {
      "simple": "Gap-8 flex row; inactive: transparent + border #b8b1a5; active: dark fill + cream text.",
      "details": "Browser-style tabs with bottom border; inactive: #e9e3d9; active: #fff8ea + golden border #b79c6a."
    },

    "Input": {
      "default": "border 1px #c7c0b3, radius-8, padding 8px 12px, bg #fffdfa, font 14px sans",
      "textarea": "Same border/bg. Font: IBM Plex Mono 13px. min-height 220px.",
      "select": "Same as input. select[multiple] min-height 140px."
    },

    "ScoreSliders": {
      "range": "1–5, step 1. Inline label + numeric readout.",
      "required": "Asterisk indicator + .input-required class on the range."
    },

    "StatusText": {
      "ok": "#2f9e44 bold",
      "failed": "#c92a2a bold",
      "pending": "#766f66 bold"
    },

    "Pre": {
      "dark": "bg #171615, text #f9f6ef, radius-12",
      "light": "bg #f6f1e6, text #1b1a17, border 1px #e1d8cb, max-height 240px, white-space pre-wrap"
    },

    "Table": {
      "cell": "border-bottom 1px #e1dbcf, padding 6px 8px, font 13px, text-align left"
    }
  }
}
